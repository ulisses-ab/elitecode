# Server
PORT=3030

# Auth
JWT_SECRET=change-me-use-a-long-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/leetcode_clone?schema=public

# Queue (Redis / Upstash)
REDIS_URL=redis://localhost:6379

# Submission rate limiting
SUBMISSION_RATE_LIMIT_MAX=4
SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=120

# Object storage (Cloudflare R2 or any S3-compatible service)
S3_BUCKET_NAME=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3030/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:3030/api/auth/github/callback

# URLs
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:5173/oauth-return
CORS_ORIGIN=http://localhost:5173

# Optional: Discord webhook for bug reports
DISCORD_WEBHOOK_URL=
