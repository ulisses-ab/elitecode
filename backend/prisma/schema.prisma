generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  handle          String          @unique
  email           String
  role            String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  oAuthIdentities OAuthIdentity[]
  problems        Problem[]       @relation("CreatedProblems")
  submissions     Submission[]
}

model OAuthIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Problem {
  id                  String         @id @default(cuid())
  slug                String         @unique
  title               String
  description         String         @default("")
  statement           String
  difficulty          String
  tags                String[]       @default([])
  creatorId           String
  defaultTestsFileKey String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  creator             User           @relation("CreatedProblems", fields: [creatorId], references: [id])
  setups              ProblemSetup[]
  submissions         Submission[]
}

model ProblemSetup {
  id              String       @id @default(cuid())
  problemId       String
  language        String
  info            String
  runnerFileKey   String?
  testsFileKey    String?
  templateFileKey String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  problem         Problem      @relation(fields: [problemId], references: [id])
  submissions     Submission[]
}

model Submission {
  id             String       @id @default(cuid())
  userId         String
  problemId      String
  setupId        String
  codeFileKey    String
  resultsFileKey String?
  status         String
  temporary      Boolean
  runtimeMs      Int?
  memoryKb       Int?
  submittedAt    DateTime
  finishedAt     DateTime?
  problem        Problem      @relation(fields: [problemId], references: [id])
  setup          ProblemSetup @relation(fields: [setupId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}
