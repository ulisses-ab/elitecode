# Backend API base URL (used to post execution results)
BACKEND_URL=http://localhost:3030/api

# JWT for the execution-engine service account (role = EXECUTION_ENGINE in the DB)
BACKEND_TOKEN=your-execution-engine-jwt

# Queue (same Redis instance as the backend)
REDIS_URL=redis://localhost:6379

# Object storage (same credentials as the backend)
S3_BUCKET_NAME=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Docker image used to sandbox user code
EXECUTOR_DOCKER_IMAGE=leetcode-executor:latest

# Number of jobs processed concurrently
EXECUTOR_CONCURRENCY=4
